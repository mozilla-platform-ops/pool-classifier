# Local Terraform state and secrets — never commit.
# (.terraform.lock.hcl is intentionally NOT ignored — commit it to pin providers.)
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Holds db_password and IAP client secret.
terraform.tfvars
*.auto.tfvars

# Saved plan files embed sensitive values (db_password, DSN) — never commit.
tfplan
*.tfplan

# ...but keep the committed example.
!terraform.tfvars.example
