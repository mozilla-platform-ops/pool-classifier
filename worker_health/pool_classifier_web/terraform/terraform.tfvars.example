project_id = "relops-pool-classifier"
region     = "us-west1"
domain     = "pool-classifier.relops.mozilla.com"

db_password = "CHANGE_ME" # pragma: allowlist secret

# IAP OAuth client — create manually in Console (Google Auth Platform → Clients →
# Web application; set redirect URI to
# https://iap.googleapis.com/v1/oauth/clientIds/<CLIENT_ID>:handleRedirect).
iap_oauth2_client_id     = "REPLACE_WITH_CLIENT_ID.apps.googleusercontent.com"
iap_oauth2_client_secret = "REPLACE_WITH_CLIENT_SECRET" # pragma: allowlist secret

iap_authorized_members = ["domain:mozilla.com"]
